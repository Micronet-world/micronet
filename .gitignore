# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# TypeScript declaration build artifacts — these belong in dist/, never in src/.
# (kernel/sdk/apps tsconfigs emit declarations; guard against them leaking into src/)
kernel/src/**/*.d.ts
kernel/src/**/*.d.ts.map
sdk/src/**/*.d.ts
sdk/src/**/*.d.ts.map
apps/src/**/*.d.ts
apps/src/**/*.d.ts.map

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
